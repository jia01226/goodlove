# 复制这个文件为 .env，填上你自己的值（.env 永不上传到 git）
#
# === 三选一：填你用的那家的"网址 + 密钥" ===
#
# ① 中转站（国内推荐：人民币/支付宝付款、低延迟。注意隐私：数据会过中转服务器）
#    向中转站要 base_url 和 key，base_url 通常长这样（结尾到 /v1）：
# API_BASE=https://你的中转域名/v1
# API_KEY=中转给你的密钥
# MODEL=claude-sonnet-4-5            # 中转一般用官方型号名，向客服确认
#
# ② OpenRouter（全球，但需可充值的卡）
# API_BASE=https://openrouter.ai/api/v1
# API_KEY=sk-or-xxx
# MODEL=anthropic/claude-sonnet-4.5
#
# ③ 官方（需外币卡）
# API_BASE=https://api.anthropic.com/v1     # 注意：官方原生接口格式略不同，走中转/OpenRouter 最省事
# API_KEY=sk-ant-xxx
#
# --- 默认占位（请按上面三选一覆盖）---
API_BASE=https://openrouter.ai/api/v1
API_KEY=填这里
MODEL=anthropic/claude-sonnet-4.5

# 服务监听端口（Nginx 反代到这里）
PORT=8000

# 可选：前端访问口令（留空则不需要）。多一层保护。
ACCESS_PASSCODE=

# 主动推送/消息的署名（这个 AI 叫什么）。改完重启生效。
APP_NAME=助手

# 主动找你：Bark 推送地址（装 Bark App 后给你的，形如 https://api.day.app/你的key）
BARK_URL=

# 手机行踪上报口令（iOS「快捷指令」打开某 app 时悄悄 POST /api/track?app=小红书&token=这个）
# 留空则复用上面的 ACCESS_PASSCODE。建议单独设一个，别和登录口令一样。
TRACK_TOKEN=

# === 向量记忆（精准想起最相关的记忆，记再多也不糊）===
# 默认走"中转的 embeddings 接口"，轻量、不占内存（推荐）。
# 不填则复用上面的 API_BASE / API_KEY。
EMBED_BACKEND=gateway              # gateway=用中转(推荐) | local=服务器本地模型(重，4G内存慎用)
EMBED_MODEL=text-embedding-3-small # 向中转客服确认它支持的嵌入模型名（如 bge-m3、text-embedding-3-small）
# EMBED_API_BASE=                  # 嵌入若用另一家，单独填；留空=复用 API_BASE
# EMBED_API_KEY=                   # 同上，留空=复用 API_KEY
# LOCAL_EMBED_MODEL=BAAI/bge-small-zh-v1.5   # EMBED_BACKEND=local 时用的中文模型
# FULL_MEMORY_LIMIT=60             # 记忆条数 ≤ 此值就全量塞，超过才启用向量精挑
# VEC_TOPK=12                      # 每次精挑多少条最相关的记忆
# VEC_SEM_WEIGHT=0.7               # 语义相似 vs 词面重合 的权重(0~1)
