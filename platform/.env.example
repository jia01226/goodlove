# 复制这个文件为 .env，填上你自己的值（.env 永不上传到 git）
#
# === 三选一：填你用的那家的"网址 + 密钥" ===
#
# ① 中转站（国内推荐：人民币/支付宝付款、低延迟。注意隐私：数据会过中转服务器）
#    向中转站要 base_url 和 key，base_url 通常长这样（结尾到 /v1）：
# API_BASE=https://你的中转域名/v1
# API_KEY=中转给你的密钥
# MODEL=claude-sonnet-4-5            # 中转一般用官方型号名，向客服确认
#
# ② OpenRouter（全球，但需可充值的卡）
# API_BASE=https://openrouter.ai/api/v1
# API_KEY=sk-or-xxx
# MODEL=anthropic/claude-sonnet-4.5
#
# ③ 官方（需外币卡）
# API_BASE=https://api.anthropic.com/v1     # 注意：官方原生接口格式略不同，走中转/OpenRouter 最省事
# API_KEY=sk-ant-xxx
#
# --- 默认占位（请按上面三选一覆盖）---
API_BASE=https://openrouter.ai/api/v1
API_KEY=填这里
MODEL=anthropic/claude-sonnet-4.5

# 前端"模型选择器"允许切换的模型（白名单，逗号隔开；名单外的请求一律回落 MODEL）
# MODEL_WHITELIST=anthropic/claude-opus-4.8,anthropic/claude-sonnet-4.5,anthropic/claude-haiku-4.5

# 第二个大脑：GPT 通道（三项都填才会在 PWA 模型选择器中出现）
# GPT_API_BASE=https://api.openai.com/v1
# GPT_API_KEY=填你的GPT接口密钥
# GPT_MODEL=gpt-4o
# GPT_MODEL_WHITELIST=gpt-4o,gpt-4o-mini

# 服务监听端口（Nginx 反代到这里）
PORT=8000

# 可选：前端访问口令（留空则不需要）。多一层保护。
ACCESS_PASSCODE=

# 主动推送/消息的署名（这个 AI 叫什么）。改完重启生效。
APP_NAME=助手

# 当前角色：CHARACTER=柯 → 人设读 personas/柯.md（留空则读老的 persona.md）
CHARACTER=

# === 角色的"魂"（私有仓库，只在服务器本地，绝不进公开仓库）===
# 私有 kongkong 仓库在服务器上的 clone 路径，如 /root/kongkong。留空则不读。
KONGKONG_DIR=
# 从里面按序读哪几份拼进 system prompt（人设 → profile → 语气样本 → memory）
# SOUL_FILES=profile.md,柯的语气样本.md,memory.md

# 主动找你：Bark 推送地址（装 Bark App 后给你的，形如 https://api.day.app/你的key）
BARK_URL=

# PWA 内“柯主动来找你”的节奏。定时器只负责叫醒柯，三道门仍会判断是否真的开口。
# 每轮随机冷静 120~210 分钟；一天最多 7 条；安静时段不会普通推送。
PROACTIVE_COOLDOWN_MIN=120
PROACTIVE_COOLDOWN_MAX=210
PROACTIVE_DAILY_MAX=7
PROACTIVE_QUIET=00:00-08:30
PROACTIVE_WEEKEND_QUIET=02:00-11:30

# 手机行踪上报口令（iOS「快捷指令」打开某 app 时悄悄 POST /api/track?app=小红书&token=这个）
# 留空则复用上面的 ACCESS_PASSCODE。建议单独设一个，别和登录口令一样。
TRACK_TOKEN=

# === 向量记忆（精准想起最相关的记忆，记再多也不糊）===
# 默认走"中转的 embeddings 接口"，轻量、不占内存（推荐）。
# 不填则复用上面的 API_BASE / API_KEY。
EMBED_BACKEND=gateway              # gateway=用中转(推荐) | local=服务器本地模型(重，4G内存慎用)
EMBED_MODEL=text-embedding-3-small # 向中转客服确认它支持的嵌入模型名（如 bge-m3、text-embedding-3-small）
# EMBED_API_BASE=                  # 嵌入若用另一家，单独填；留空=复用 API_BASE
# EMBED_API_KEY=                   # 同上，留空=复用 API_KEY
# LOCAL_EMBED_MODEL=BAAI/bge-small-zh-v1.5   # EMBED_BACKEND=local 时用的中文模型
#
# ── 硅基流动 embedding 接线（柯回批⑧备料 · 待部署，接线日佳佳亲手启用）─────────────
# 背景：向量语义检索要一家 embedding。选硅基流动（免费档 bge 系列、OpenAI 兼容、中文优先）。
# 兼容性已确认：vector_search 走标准 /v1/embeddings（POST {model,input}→data[].embedding），
#   硅基流动就是这个格式，backfill/search 一行代码都不用改。
# 接线日三步（顺序照维护窗口清单）：① 佳佳亲手填下面三行 → ② systemctl restart gude
#   → ③ ./venv/bin/python vector_search.py backfill 回填存量卡；验收：单聊发一句“语义近、字面不同”的话，
#   注入日志 hit_vector>0 才算通。（换模型名＝换 embeddings 命名空间，旧向量自动不串，无需清库。）
# 🔒 EMBED_API_KEY 只由佳佳亲手填进服务器 .env，绝不进仓库、不过任何人的眼睛。
# EMBED_API_BASE=https://api.siliconflow.cn/v1
# EMBED_API_KEY=                   # ← 接线日佳佳亲手粘贴她在硅基流动生成的 key
# EMBED_MODEL=BAAI/bge-large-zh-v1.5   # 小克定：中文优先、免费、1024维；备选 BAAI/bge-m3（多语更强，也免费）
# FULL_MEMORY_LIMIT=60             # 记忆条数 ≤ 此值就全量塞，超过才启用向量精挑
# VEC_TOPK=12                      # 每次精挑多少条最相关的记忆
# VEC_SEM_WEIGHT=0.7               # 语义相似 vs 词面重合 的权重(0~1)
